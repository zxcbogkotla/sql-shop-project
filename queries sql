-- Query 1: customers from Prague
SELECT * FROM customers
WHERE city = 'Prague';

-- Query 2: total spending per customer
SELECT c.name, SUM(p.price * o.quantity) as total
FROM orders o
JOIN products p ON o.product_id = p.id
JOIN customers c ON o.customer_id = c.id
GROUP BY o.customer_id;

-- Query 3: top product by quantity sold
SELECT p.name, SUM(o.quantity) as total
FROM orders o
JOIN products p ON o.product_id = p.id
GROUP BY p.name
ORDER BY total DESC
LIMIT 1;

-- Query 4: total revenue per product category
SELECT p.category, SUM(p.price * o.quantity) as revenue
FROM orders o
JOIN products p ON o.product_id = p.id
GROUP BY p.category
ORDER BY revenue DESC;

-- Query 5: customers who spent more than 500
SELECT c.name, SUM(p.price * o.quantity) as total
FROM orders o
JOIN products p ON o.product_id = p.id
JOIN customers c ON o.customer_id = c.id
GROUP BY c.id
HAVING total > 500
ORDER BY total DESC;
