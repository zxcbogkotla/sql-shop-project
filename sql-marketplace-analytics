-- Query 1: Top 3 sellers by revenue
SELECT s.name, SUM(p.price * o.quantity) as revenue
FROM orders o
JOIN products p ON o.product_id = p.id
JOIN sellers s ON p.seller_id = s.id
GROUP BY s.name
ORDER BY revenue DESC
LIMIT 3;

-- Query 2: Average rating per seller
SELECT s.name, AVG(r.rating) AS rating
FROM reviews r
JOIN orders o ON r.order_id = o.id
JOIN products p ON o.product_id = p.id
JOIN sellers s ON p.seller_id = s.id
GROUP BY s.name
ORDER BY rating DESC;

-- Query 3: Sellers with more than 50% cancelled orders
SELECT s.name,
    COUNT(*) as total_orders,
    COUNT(CASE WHEN o.status = 'cancelled' THEN 1 END) as cancelled_orders,
    ROUND(COUNT(CASE WHEN o.status = 'cancelled' THEN 1 END) * 100.0 / COUNT(*), 1) as cancelled_percent
FROM orders o
JOIN products p ON o.product_id = p.id
JOIN sellers s ON p.seller_id = s.id
GROUP BY s.name
HAVING cancelled_percent > 50;

-- Query 4: Customers who bought from at least 3 different categories
SELECT c.name, COUNT(DISTINCT p.category) as categories
FROM customers c
JOIN orders o ON c.id = o.customer_id
JOIN products p ON o.product_id = p.id
GROUP BY c.name
HAVING categories >= 3;

-- Query 5: Best month by revenue for each seller (CTE)
WITH monthly AS (
    SELECT s.name, strftime('%m', o.order_date) as month, SUM(p.price * o.quantity) as revenue
    FROM sellers s
    JOIN products p ON p.seller_id = s.id
    JOIN orders o ON o.product_id = p.id
    GROUP BY s.name, strftime('%m', o.order_date)
)
SELECT name, month, MAX(revenue) as best_revenue
FROM monthly
GROUP BY name;
