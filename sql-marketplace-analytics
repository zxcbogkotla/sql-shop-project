-- Create tables
CREATE TABLE sellers (
    id INTEGER PRIMARY KEY,
    name TEXT,
    country TEXT,
    joined_date TEXT
);

CREATE TABLE products (
    id INTEGER PRIMARY KEY,
    seller_id INTEGER,
    name TEXT,
    price REAL,
    category TEXT
);

CREATE TABLE customers (
    id INTEGER PRIMARY KEY,
    name TEXT,
    country TEXT,
    joined_date TEXT
);

CREATE TABLE orders (
    id INTEGER PRIMARY KEY,
    customer_id INTEGER,
    product_id INTEGER,
    quantity INTEGER,
    order_date TEXT,
    status TEXT
);

CREATE TABLE reviews (
    id INTEGER PRIMARY KEY,
    order_id INTEGER,
    rating INTEGER,
    comment TEXT
);

